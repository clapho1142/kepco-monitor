<div key={i} style={{
  display:"flex",
  gap:16,
  background:"#0d1b3e",
  border:"1px solid rgba(255,255,255,0.08)",
  borderRadius:14,
  padding:16,
  transition:"all 0.2s ease"
}}>

  {/* 썸네일 */}
  <div style={{
    width:110,
    height:80,
    borderRadius:10,
    overflow:"hidden",
    flexShrink:0,
    background:"#1e293b"
  }}>
    <img 
      src={art.thumbnail}
      alt=""
      style={{width:"100%",height:"100%",objectFit:"cover"}}
    />
  </div>

  {/* 콘텐츠 */}
  <div style={{flex:1,display:"flex",flexDirection:"column",gap:6}}>

    {/* 제목 */}
    <a 
      href={art.url}
      target="_blank"
      rel="noopener noreferrer"
      style={{
        fontSize:15,
        fontWeight:700,
        color:"#e2e8f0",
        lineHeight:1.5,
        textDecoration:"none"
      }}
      onMouseEnter={e=>{
        e.currentTarget.style.color="#60a5fa";
      }}
      onMouseLeave={e=>{
        e.currentTarget.style.color="#e2e8f0";
      }}
    >
      {art.title}
    </a>

    {/* 메타 */}
    <div style={{
      fontSize:12,
      color:"#94a3b8",
      display:"flex",
      gap:10,
      alignItems:"center"
    }}>
      <span>📰 {art.source}</span>
      <span>📅 {fmtDate(art.date)}</span>
      {art.region !== "기타" && <span>📍 {art.region}</span>}
    </div>

    {/* 요약 */}
    {art.summary && (
      <div style={{
        fontSize:13,
        color:"#94a3b8",
        lineHeight:1.6
      }}>
        {art.summary}
      </div>
    )}

    {/* 액션 버튼 */}
    <div style={{marginTop:6,display:"flex",gap:8}}>

      <a href={art.url} target="_blank"
        style={{
          fontSize:12,
          padding:"6px 10px",
          borderRadius:8,
          background:"#3B82F6",
          color:"#fff",
          textDecoration:"none",
          fontWeight:600
        }}>
        네이버에서 보기
      </a>

      {art.originallink && (
        <a href={art.originallink} target="_blank"
          style={{
            fontSize:12,
            padding:"6px 10px",
            borderRadius:8,
            border:"1px solid rgba(255,255,255,0.2)",
            color:"#cbd5e1",
            textDecoration:"none"
          }}>
          원문
        </a>
      )}

    </div>
  </div>
</div>
